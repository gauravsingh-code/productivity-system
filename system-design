    <script>
        function toggleCheck(element) {
            const checkbox = element.querySelector('.checkbox');
            checkbox.classList.toggle('checked');
            updateProgress();
            saveProgress();
        }

        function updateProgress() {
            const allCheckboxes = document.querySelectorAll('.checkbox');
            const checkedBoxes = document.querySelectorAll('.checkbox.checked');
            const allSelects = document.querySelectorAll('.status-select');
            
            let doneCount = 0;
            let inProgressCount = 0;
            allSelects.forEach(select => {
                if (select.value === 'done') doneCount++;
                if (select.value === 'in-progress') inProgressCount++;
            });

            const totalTopics = 85;
            const completedTopics = checkedBoxes.length;
            
            document.getElementById('completedTopics').textContent = completedTopics;
            document.getElementById('inProgressTopics').textContent = inProgressCount;
            
            const progressPercentage = Math.round((completedTopics / totalTopics) * 100);
            document.getElementById('overallProgress').textContent = progressPercentage + '%';
            document.getElementById('progressBar').style.width = progressPercentage + '%';
        }

        function saveProgress() {
            const checkboxStates = [];
            document.querySelectorAll('.checkbox').forEach((checkbox) => {
                checkboxStates.push(checkbox.classList.contains('checked'));
            });
            
            const selectStates = [];
            document.querySelectorAll('.status-select').forEach(select => {
                selectStates.push(select.value);
            });
            
            localStorage.setItem('sysdesign_checkboxes', JSON.stringify(checkboxStates));
            localStorage.setItem('sysdesign_selects', JSON.stringify(selectStates));
        }

        function loadProgress() {
            const checkboxStates = JSON.parse(localStorage.getItem('sysdesign_checkboxes') || '[]');
            const selectStates = JSON.parse(localStorage.getItem('sysdesign_selects') || '[]');
            
            document.querySelectorAll('.checkbox').forEach((checkbox, index) => {
                if (checkboxStates[index]) {
                    checkbox.classList.add('checked');
                }
            });
            
            document.querySelectorAll('.status-select').forEach((select, index) => {
                if (selectStates[index]) {
                    select.value = selectStates[index];
                }
            });
            
            updateProgress();
        }

        window.addEventListener('load', loadProgress);
        setInterval(saveProgress, 3000);
    </script>
