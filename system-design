<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Design Mastery Tracker</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Newsreader:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #0a0e14;
            --bg-secondary: #151a23;
            --bg-tertiary: #1f2937;
            --accent-primary: #00d4ff;
            --accent-secondary: #ff6b9d;
            --accent-tertiary: #ffd93d;
            --text-primary: #e5e7eb;
            --text-secondary: #9ca3af;
            --text-muted: #6b7280;
            --border: #374151;
            --success: #10b981;
            --grid-size: 24px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Newsreader', serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.7;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(var(--border) 1px, transparent 1px),
                linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: var(--grid-size) var(--grid-size);
            opacity: 0.3;
            z-index: -1;
            animation: gridPulse 20s ease-in-out infinite;
        }

        @keyframes gridPulse {
            0%, 100% { opacity: 0.2; }
            50% { opacity: 0.4; }
        }

        body::after {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 20%, rgba(0, 212, 255, 0.05) 0%, transparent 50%),
                        radial-gradient(circle at 80% 80%, rgba(255, 107, 157, 0.05) 0%, transparent 50%);
            z-index: -1;
            pointer-events: none;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 60px 40px;
        }

        header {
            margin-bottom: 80px;
        }

        h1 {
            font-family: 'JetBrains Mono', monospace;
            font-size: clamp(2.5rem, 8vw, 4.5rem);
            font-weight: 700;
            letter-spacing: -0.03em;
            line-height: 1.1;
            margin-bottom: 20px;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: fadeInUp 0.8s ease-out;
        }

        .subtitle {
            font-size: 1.3rem;
            color: var(--text-secondary);
            font-style: italic;
            margin-bottom: 30px;
            animation: fadeInUp 0.8s ease-out 0.2s backwards;
        }

        .header-meta {
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            color: var(--text-muted);
            animation: fadeInUp 0.8s ease-out 0.4s backwards;
        }

        .header-meta span::before {
            content: '▸';
            color: var(--accent-primary);
            margin-right: 8px;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 60px;
        }

        .stat-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            padding: 30px;
            border-radius: 12px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.3s ease;
        }

        .stat-card:hover::before { transform: scaleX(1); }
        .stat-card:hover {
            transform: translateY(-4px);
            border-color: var(--accent-primary);
            box-shadow: 0 10px 40px rgba(0, 212, 255, 0.1);
        }

        .stat-label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            margin-bottom: 10px;
        }

        .stat-value {
            font-family: 'JetBrains Mono', monospace;
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--accent-primary);
        }

        .stat-subtitle {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-top: 8px;
        }

        .section {
            margin-bottom: 80px;
        }

        .section-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 40px;
        }

        .section-number {
            font-family: 'JetBrains Mono', monospace;
            font-size: 3rem;
            font-weight: 700;
            color: var(--accent-primary);
            opacity: 0.3;
        }

        .section-title {
            font-family: 'JetBrains Mono', monospace;
            font-size: 2rem;
            font-weight: 600;
        }

        .section-title::after {
            content: '';
            display: block;
            width: 60px;
            height: 3px;
            background: linear-gradient(90deg, var(--accent-primary), transparent);
            margin-top: 10px;
        }

        .phase-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 30px;
            transition: all 0.3s ease;
        }

        .phase-card:hover {
            border-color: var(--accent-primary);
            box-shadow: 0 20px 60px rgba(0, 212, 255, 0.15);
        }

        .phase-header {
            padding: 30px;
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.1), rgba(255, 107, 157, 0.1));
            border-bottom: 1px solid var(--border);
        }

        .phase-badge {
            display: inline-block;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 6px 14px;
            background: var(--bg-tertiary);
            border: 1px solid var(--accent-primary);
            border-radius: 20px;
            color: var(--accent-primary);
            margin-bottom: 15px;
        }

        .phase-title {
            font-family: 'JetBrains Mono', monospace;
            font-size: 1.8rem;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .phase-duration {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.9rem;
            color: var(--text-secondary);
        }

        .phase-content {
            padding: 30px;
        }

        .topic-section {
            margin-bottom: 30px;
        }

        .topic-header {
            font-family: 'JetBrains Mono', monospace;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--accent-secondary);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topic-header::before {
            content: '●';
            font-size: 0.6rem;
        }

        .topic-item {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            padding: 15px;
            background: var(--bg-tertiary);
            border-radius: 8px;
            border: 1px solid transparent;
            transition: all 0.3s ease;
            cursor: pointer;
            margin-bottom: 12px;
        }

        .topic-item:hover {
            border-color: var(--accent-primary);
            background: rgba(0, 212, 255, 0.05);
        }

        .checkbox {
            width: 20px;
            height: 20px;
            border: 2px solid var(--border);
            border-radius: 4px;
            flex-shrink: 0;
            margin-top: 2px;
            position: relative;
            transition: all 0.3s ease;
        }

        .checkbox.checked {
            background: var(--accent-primary);
            border-color: var(--accent-primary);
        }

        .checkbox.checked::after {
            content: '✓';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: var(--bg-primary);
            font-size: 14px;
            font-weight: 700;
        }

        .topic-name {
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .topic-meta {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            background: var(--bg-secondary);
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid var(--border);
            margin-bottom: 40px;
        }

        th {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 20px;
            text-align: left;
            color: var(--accent-primary);
            font-weight: 600;
            background: var(--bg-tertiary);
            border-bottom: 2px solid var(--border);
        }

        td {
            padding: 20px;
            border-bottom: 1px solid var(--border);
            vertical-align: top;
        }

        tr:hover {
            background: rgba(0, 212, 255, 0.05);
        }

        tr:last-child td {
            border-bottom: none;
        }

        .week-number {
            font-family: 'JetBrains Mono', monospace;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--accent-primary);
        }

        .week-topics {
            list-style: none;
            margin: 8px 0;
        }

        .week-topics li {
            padding: 6px 0;
            padding-left: 20px;
            position: relative;
            color: var(--text-secondary);
        }

        .week-topics li::before {
            content: '→';
            position: absolute;
            left: 0;
            color: var(--accent-tertiary);
        }

        .resource-tag {
            display: inline-block;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            padding: 4px 10px;
            background: var(--bg-tertiary);
            border-radius: 4px;
            margin: 4px 4px 4px 0;
            color: var(--accent-tertiary);
            border: 1px solid rgba(255, 217, 61, 0.3);
        }

        .status-select {
            font-family: 'JetBrains Mono', monospace;
            padding: 8px 12px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text-primary);
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .status-select:hover {
            border-color: var(--accent-primary);
        }

        .tip-card {
            background: linear-gradient(135deg, rgba(255, 107, 157, 0.1), rgba(255, 217, 61, 0.1));
            border: 1px solid var(--border);
            border-left: 4px solid var(--accent-secondary);
            border-radius: 8px;
            padding: 25px;
            margin-bottom: 20px;
        }

        .tip-title {
            font-family: 'JetBrains Mono', monospace;
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 12px;
            color: var(--accent-secondary);
        }

        .tip-content {
            color: var(--text-secondary);
            line-height: 1.8;
        }

        .tip-content ul {
            list-style: none;
            margin-top: 10px;
        }

        .tip-content li {
            padding: 6px 0;
            padding-left: 25px;
            position: relative;
        }

        .tip-content li::before {
            content: '✓';
            position: absolute;
            left: 0;
            color: var(--success);
            font-weight: 700;
        }

        .progress-section {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 30px;
            margin-bottom: 40px;
        }

        .progress-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .progress-title {
            font-family: 'JetBrains Mono', monospace;
            font-size: 1.2rem;
            font-weight: 600;
        }

        .progress-percentage {
            font-family: 'JetBrains Mono', monospace;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--accent-primary);
        }

        .progress-bar-container {
            width: 100%;
            height: 12px;
            background: var(--bg-tertiary);
            border-radius: 6px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
            border-radius: 6px;
            transition: width 0.5s ease;
            position: relative;
        }

        .progress-bar::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            animation: shimmer 2s infinite;
        }

        @keyframes shimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }

        footer {
            margin-top: 100px;
            padding: 40px 0;
            border-top: 1px solid var(--border);
            text-align: center;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        footer a {
            color: var(--accent-primary);
            text-decoration: none;
        }

        footer a:hover {
            color: var(--accent-secondary);
        }

        @media (max-width: 768px) {
            .container { padding: 40px 20px; }
            h1 { font-size: 2.5rem; }
            .section-number { font-size: 2rem; }
            .section-title { font-size: 1.5rem; }
            .stats-grid { grid-template-columns: 1fr; }
            .header-meta { flex-direction: column; gap: 15px; }
            table { display: block; overflow-x: auto; }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>System Design Mastery</h1>
            <p class="subtitle">A Structured 12-Week Journey from Fundamentals to Expertise</p>
            <div class="header-meta">
                <span>Duration: 12 Weeks</span>
                <span>Daily: 1-2 Hours</span>
                <span>Target: Senior Engineer</span>
                <span>Focus: HLD + LLD</span>
            </div>
        </header>

        <div class="progress-section">
            <div class="progress-header">
                <div class="progress-title">Overall Progress</div>
                <div class="progress-percentage" id="overallProgress">0%</div>
            </div>
            <div class="progress-bar-container">
                <div class="progress-bar" id="progressBar" style="width: 0%"></div>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">Total Topics</div>
                <div class="stat-value">85</div>
                <div class="stat-subtitle">HLD + LLD Combined</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Completed</div>
                <div class="stat-value" id="completedTopics">0</div>
                <div class="stat-subtitle">Keep Going!</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">In Progress</div>
                <div class="stat-value" id="inProgressTopics">0</div>
                <div class="stat-subtitle">Active Learning</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Practice Problems</div>
                <div class="stat-value">30+</div>
                <div class="stat-subtitle">Real-world Systems</div>
            </div>
        </div>

        <!-- Phase 1 -->
        <section class="section">
            <div class="section-header">
                <div class="section-number">01</div>
                <h2 class="section-title">Learning Phases</h2>
            </div>

            <div class="phase-card">
                <div class="phase-header">
                    <div class="phase-badge">Phase 01</div>
                    <h3 class="phase-title">Foundation Building</h3>
                    <div class="phase-duration">Weeks 1-3 • Beginner Level</div>
                </div>
                <div class="phase-content">
                    <div class="topic-section">
                        <div class="topic-header">High-Level Design (HLD)</div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">System Design Basics & CAP Theorem</div>
                                <div class="topic-meta">Week 1 • Fundamentals</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Scalability & Load Balancing</div>
                                <div class="topic-meta">Week 1-2 • LB algorithms</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Caching & CDN Basics</div>
                                <div class="topic-meta">Week 2 • Strategies, eviction</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">SQL vs NoSQL</div>
                                <div class="topic-meta">Week 2-3 • ACID vs BASE</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">REST API Design</div>
                                <div class="topic-meta">Week 3 • Best practices</div>
                            </div>
                        </div>
                    </div>
                    <div class="topic-section">
                        <div class="topic-header">Low-Level Design (LLD)</div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">SOLID Principles</div>
                                <div class="topic-meta">Week 1 • OOP foundation</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Creational Patterns</div>
                                <div class="topic-meta">Week 2 • Singleton, Factory, Builder</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Structural Patterns</div>
                                <div class="topic-meta">Week 3 • Adapter, Decorator, Proxy</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">UML & Class Design</div>
                                <div class="topic-meta">Week 3 • Diagrams</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Phase 2 -->
            <div class="phase-card">
                <div class="phase-header">
                    <div class="phase-badge">Phase 02</div>
                    <h3 class="phase-title">Intermediate Concepts</h3>
                    <div class="phase-duration">Weeks 4-7 • Intermediate Level</div>
                </div>
                <div class="phase-content">
                    <div class="topic-section">
                        <div class="topic-header">High-Level Design (HLD)</div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Sharding & Partitioning</div>
                                <div class="topic-meta">Week 4 • Consistent hashing</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Message Queues & Kafka</div>
                                <div class="topic-meta">Week 4-5 • Event-driven</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Microservices Architecture</div>
                                <div class="topic-meta">Week 5 • Service discovery</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Consistency & Transactions</div>
                                <div class="topic-meta">Week 6 • 2PC, Saga</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Rate Limiting</div>
                                <div class="topic-meta">Week 6 • Algorithms</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Search & Elasticsearch</div>
                                <div class="topic-meta">Week 7 • Indexing</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">WebSockets & Real-time</div>
                                <div class="topic-meta">Week 7 • Live systems</div>
                            </div>
                        </div>
                    </div>
                    <div class="topic-section">
                        <div class="topic-header">Low-Level Design (LLD)</div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Behavioral Patterns</div>
                                <div class="topic-meta">Week 4-5 • Observer, Strategy, Command</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Concurrency Patterns</div>
                                <div class="topic-meta">Week 5-6 • Thread safety</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">State Machines</div>
                                <div class="topic-meta">Week 6 • FSM design</div>
                            </div>
                        </div>
                        <div class="topic-item" onclick="toggleCheck(this)">
                            <div class="checkbox"></div>
                            <div class="topic-content">
                                <div class="topic-name">Clean Architecture</div>
                                <div class="topic-meta">Week 7 • Hexagonal, Onion</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Phase 3 -->
            <div class="phase-card">
                <div class="phase-header">
                    <div class="phase-badge">Phase 03</div>
                    <h3 class="phase-title">Advanced Architecture</h3>
                    <div class="phase-duration">Weeks 8-10 • Advanced Level</div>
                </div>
                <div class="phase-content">
                    <div class="topic-section">
